<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>{{{styles}}}</style>
</head>
<body>
  <div class="report-container">
    <header class="report-header">
      <h1>{{title}}</h1>
      {{#if description}}
      <p class="report-description">{{description}}</p>
      {{/if}}
      <p class="report-meta">Generated: {{generatedAt}} &middot; {{totalRows}} records</p>
    </header>

    <main class="report-body">
      <table class="report-table">
        <thead>
          <tr>
            <th class="row-number">#</th>
            {{#each columns}}
            <th>{{this.label}}</th>
            {{/each}}
          </tr>
        </thead>
        <tbody>
          {{#each rows}}
          <tr>
            <td class="row-number">{{inc @index}}</td>
            {{#each ../columns}}
            <td>{{formatValue (lookup ../this this.key) this.format}}</td>
            {{/each}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    </main>

    <footer class="report-footer">
      <p>Report: {{title}} &middot; Total records: {{totalRows}}</p>
    </footer>
  </div>
</body>
</html>
